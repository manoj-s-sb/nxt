#!/usr/bin/env bash
#
# Pre-commit hook — runs frontend + backend checks before allowing a commit.
# Activate once with: ./scripts/setup-hooks.sh
#
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Colors
RED='\033[0;31m'
GRN='\033[0;32m'
YLW='\033[1;33m'
DIM='\033[2m'
RST='\033[0m'

STAGED_FILES="$(git diff --cached --name-only --diff-filter=ACMR)"
FRONTEND_STAGED="$(echo "$STAGED_FILES" | grep -E '^frontend/' || true)"
BACKEND_STAGED="$(echo "$STAGED_FILES" | grep -E '^backend/' || true)"

if [ -z "$FRONTEND_STAGED" ] && [ -z "$BACKEND_STAGED" ]; then
  echo -e "${DIM}pre-commit: no frontend or backend files staged — skipping.${RST}"
  exit 0
fi

FAILED=0

run_check() {
  local name="$1"
  local dir="$2"
  local cmd="$3"

  echo ""
  echo -e "${YLW}→ ${name}${RST} ${DIM}(cd ${dir} && ${cmd})${RST}"
  if (cd "$dir" && eval "$cmd"); then
    echo -e "  ${GRN}✓ ${name} passed${RST}"
  else
    echo -e "  ${RED}✗ ${name} FAILED${RST}"
    FAILED=1
  fi
}

if [ -n "$FRONTEND_STAGED" ]; then
  run_check "frontend checks" "frontend" "npm run check"
fi

if [ -n "$BACKEND_STAGED" ]; then
  run_check "backend checks" "backend" "make check"
fi

echo ""
if [ "$FAILED" -ne 0 ]; then
  echo -e "${RED}✗ commit blocked — fix the issues above.${RST}"
  echo -e "${DIM}  tip: 'npm run fix' (frontend) · 'make fix' (backend) auto-corrects most.${RST}"
  exit 1
fi

echo -e "${GRN}✓ all checks passed — proceeding with commit.${RST}"
